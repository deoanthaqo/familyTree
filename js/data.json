    {
      "id": "G3-7",
      "name": "Avicenna Azarine Mumtaza",
      "gender": "Perempuan",
      "dob": "24 Februari 2015",
      "dod": null,
      "pob": "Mojokerto",
      "burial_place": null,
      "profession": "Pelajar",
      "education": "SDN 4 Kebonsari",
      "bio": "Avicenna adalah anak pertama dari pasangan Imama Nanda Anthaqo dan Khoiron Fanani. Cenna adalah sosok yang cerdas dan penuh semangat, terutama dalam bidang sains dan matematika. Ketertarikannya pada bidang ini dibuktikan dengan prestasinya sebagai peserta OSN Matematika yang mewakili sekolah, baik saat di SDN Ngasem Kediri maupun di sekolahnya yang sekarang. Sejak usia dini, Avicenna telah menunjukkan kemampuan luar biasa dalam memahami konsep-konsep ilmiah dan matematika yang kompleks. Tidak hanya unggul di bidang eksakta, ia juga memiliki talenta yang beragam, terbukti dengan keberhasilannya memenangkan lomba menulis cerpen, serta kompetisi di bidang IPA dan Bahasa Inggris. Dia sering menghabiskan waktu luangnya dengan membaca buku-buku sains dan mengikuti berbagai kegiatan ekstrakurikuler. Dengan dukungan penuh dari orang tuanya, Avicenna memiliki potensi besar untuk berkembang menjadi seorang ilmuwan atau matematikawan yang sukses di masa depan.",
      "marriage_info": null,
      "parents_id": ["G2-7", "G2-8"],
      "photo_url": "./images/G3-7.jpg"
